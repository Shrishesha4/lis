            <script>// Get raw data directly in destination
var raw = connectorMessage.getRawData();

// Use Java replaceAll to strip ASTM control characters
raw = java.lang.String.valueOf(raw).replaceAll(&apos;[\\x02\\x03\\x04\\x05\\x06]&apos;, &apos;&apos;);
raw = java.lang.String.valueOf(raw).replaceAll(&apos;[0-9A-Fa-f]{2}\\r&apos;, &apos;\r&apos;);

var lines = raw.split(&apos;\r&apos;);

var result = {
  patient: {},
  orders: [],
  results: []
};

var currentOrder = null;

for (var i = 0; i &lt; lines.length; i++) {
  var line = lines[i].trim();
  if (line.length === 0) continue;

  if (/^\d/.test(line)) {
    line = line.substring(1);
  }

  var fields = line.split(&apos;|&apos;);
  var recordType = fields[0];

  switch (recordType) {
    case &apos;H&apos;:
      result.header = {
        senderId:     fields[4] || &apos;&apos;,
        processingId: fields[11] || &apos;&apos;,
        timestamp:    fields[13] || &apos;&apos;
      };
      break;

    case &apos;P&apos;:
      result.patient = {
        patientId: fields[3] || &apos;&apos;,
        lastName:  fields[5] ? fields[5].split(&apos;^&apos;)[0] : &apos;&apos;,
        firstName: fields[5] ? fields[5].split(&apos;^&apos;)[1] : &apos;&apos;,
        dob:       fields[7] || &apos;&apos;,
        gender:    fields[8] || &apos;&apos;
      };
      break;

    case &apos;O&apos;:
      currentOrder = {
        specimenId:   fields[2] || &apos;&apos;,
        testId:       fields[4] ? java.lang.String.valueOf(fields[4]).replaceAll(&apos;\\^+&apos;, &apos;&apos;).trim() : &apos;&apos;,
        priority:     fields[5] || &apos;&apos;,
        orderTime:    fields[7] || &apos;&apos;,
        specimenType: fields[15] || &apos;&apos;,
        results:      []
      };
      result.orders.push(currentOrder);
      break;

    case &apos;R&apos;:
      var resultRecord = {
        testCode:     fields[2] ? java.lang.String.valueOf(fields[2]).replaceAll(&apos;\\^+&apos;, &apos;&apos;).trim() : &apos;&apos;,
        value:        fields[3] || &apos;&apos;,
        units:        fields[4] || &apos;&apos;,
        refRange:     fields[5] || &apos;&apos;,
        abnormalFlag: fields[6] || &apos;&apos;,
        status:       fields[8] || &apos;&apos;,
        timestamp:    fields[12] || &apos;&apos;
      };
      result.results.push(resultRecord);
      if (currentOrder) {
        currentOrder.results.push(resultRecord);
      }
      break;

    case &apos;L&apos;:
      result.status = &apos;complete&apos;;
      break;
  }
}

return JSON.stringify(result, null, 2);</script>
