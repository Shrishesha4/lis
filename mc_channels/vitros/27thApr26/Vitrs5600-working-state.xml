  <preprocessingScript>// Strip ASTM LIS2-A2 control characters
var raw = message;

// Remove STX (0x02), ETX (0x03), ENQ (0x05), EOT (0x04), ACK (0x06)
// Remove frame numbers (single digit after STX)
raw = raw.replace(/[\x02\x03\x04\x05\x06]/g, &apos;&apos;);

// Remove checksum bytes at end of each frame (2 hex chars before CR)
raw = raw.replace(/[0-9A-Fa-f]{2}\r/g, &apos;\r&apos;);

// Normalize line endings
raw = raw.replace(/\r\n/g, &apos;\r&apos;).replace(/\n/g, &apos;\r&apos;);

return raw;
